local function makeLiveryTable(car, liveryData, carId)
    local liveryTable = { ["car"] = car.Name, ["carId"] = carId, ["liveryCount"] = #liveryData, ["liveries"] = {} }
    for _, livery in ipairs(liveryData) do
        local outLivery = {
            name = sanitize(tostring(livery.liveryName)),
            vehicleColor = tostring(getColor(livery.vehicleColor)),
            liveryColor = tostring(getColor(livery.liveryColor)),
            liveryTransparency = tostring(livery.liveryTransparency),
            ELS = { park = livery.ParkPatterns, stg1 = livery.Stage1Patterns, stg2 = livery.Stage2Patterns, stg3 = livery.Stage3Patterns, color = livery.ELSColor },
            approved = livery.isApproved == true and "Approved" or liveryDenialReasons[livery.isApproved],
            textures = {}
        }
        for side, id in pairs(livery.textureIds) do outLivery.textures[side] = tostring(id) end
        table.insert(liveryTable.liveries, outLivery)
    end
    return liveryTable
end

local function getLiveries()
    local success, data = getVehicleSpawnData:Call("News Station Worker", workspace.VehicleSpawners.NewsStationWorker_Spawners.Stand.SpawnClicker.InteractionAttachment):Await()
    if success and data.liveries then
        local liveryTables = {}
        for team, val in pairs(data.liveries) do
            liveryTables[team] = {}
            for car, carData in pairs(val) do
                local carObj = vehicles.GetCarById(categoryMap[team] or "Civ", tonumber(car))
                table.insert(liveryTables[team], makeLiveryTable(carObj, carData, car))
            end
        end
        return liveryTables
    end
    return {}
end

local function getUniforms()
    local uniformTable = {}
    for _, team in ipairs(replicatedStorage.ReplicatedState.Uniforms:GetChildren()) do
        uniformTable[team.Name] = {}
        for _, uniform in ipairs(team:GetChildren()) do
            if uniform:FindFirstChild("CustomUniform") then
                uniformTable[team.Name][uniform.Name] = {
                    shirt = extractId(tostring(uniform.Shirt.ShirtTemplate)),
                    pants = extractId(tostring(uniform.Pants.PantsTemplate))
                }
            end
        end
    end
    return uniformTable
end

local function getELS() return replicatedStorage.FE.GetCustomELS:InvokeServer() end

local function getMapTemplates()
    local mapLayouts = {}
    local layouts = workspace:FindFirstChild("MapLayouts")
    if not layouts then return {} end
    for _, template in ipairs(layouts:GetChildren()) do
        local layoutName = template:GetAttribute("LayoutName") or template.Name
        mapLayouts[layoutName] = {}
        local props = template:FindFirstChild("Props")
        if props then
            for _, prop in ipairs(props:GetChildren()) do
                table.insert(mapLayouts[layoutName], {
                    name = prop:GetAttribute("PropName") or prop.Name,
                    position = tostring(prop.WorldPivot.Position)
                })
            end
        end
    end
    return mapLayouts
end

